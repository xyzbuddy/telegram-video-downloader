# ==========================================
# Telegram Video Downloader Configuration Template
# Copy this file to a new file named '.env' and fill in your values.
# ==========================================

# Telegram API Credentials
# Get these from https://my.telegram.org (API Development Tools)
API_ID=21751784
API_HASH=your_api_hash_here

# Channel / Group ID or Username to download from.
# Private channel IDs usually start with -100 (e.g., -1003098918811).
# Public channels can use the username (e.g., telegram_channel_username).
CHANNEL_ID=-1003098918811

# Maximum download limit (in bytes). Default is 20 GB.
# 20 GB = 21474836480 bytes (20 * 1024 * 1024 * 1024)
MAX_TOTAL_SIZE=21474836480

# Directory name where downloads will be saved
DOWNLOADS_DIR=downloads
